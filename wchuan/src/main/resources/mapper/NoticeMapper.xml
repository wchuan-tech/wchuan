<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wchuan.system.mapper.NoticeMapper">

    <resultMap type="com.wchuan.system.domain.entity.SysNotice" id="SysNoticeResult">
        <id     property="id"           column="id"           />
        <result property="title"        column="title"        />
        <result property="content"      column="content"      />
        <result property="type"         column="type"         />
        <result property="tenantId"     column="tenant_id"    />
        <result property="tenantName"   column="tenant_name"  />
        <result property="createBy"     column="create_by"    />
        <result property="createTime"   column="create_time"  />
    </resultMap>

    <select id="selectNoticeMixed" resultMap="SysNoticeResult">
        SELECT n.*, t.tenant_name
        FROM sys_notice n
                 LEFT JOIN sys_tenant t ON n.tenant_id = t.id
        WHERE (n.tenant_id = #{tenantId} OR n.type = '1')
        ORDER BY n.create_time DESC
    </select>

    <select id="selectTenantNameById" parameterType="java.lang.Long" resultType="java.lang.String">
        SELECT t.tenant_name
        FROM sys_tenant t
        WHERE t.id = #{tenantId}
    </select>

</mapper>